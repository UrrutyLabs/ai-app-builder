# Neon Postgres — pooled connection (used by Next.js runtime)
DATABASE_URL=

# Neon Postgres — direct connection (used by Prisma migrations)
DIRECT_URL=

# Anthropic API key (used by packages/ai)
ANTHROPIC_API_KEY=

# 32-byte AES-256-GCM key for encrypting at-rest secrets (e.g. GitHub PATs).
# Generate one with: openssl rand -base64 32
ENCRYPTION_KEY=

# Optional model overrides (defaults defined in packages/ai/src/models.ts)
# AI_MODEL_QUESTIONS=claude-haiku-4-5-20251001
# AI_MODEL_SPEC=claude-sonnet-4-6
# AI_MODEL_PLAN=claude-opus-4-7
