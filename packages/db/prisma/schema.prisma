generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

enum Mode {
  GREENFIELD
  EXISTING_SYSTEM
}

enum FeatureStatus {
  DRAFT
  QUESTIONS_GENERATED
  ANSWERED
  SPEC_DRAFTED
  SPEC_APPROVED
  PLAN_GENERATED
}

model Project {
  id             String               @id @default(cuid())
  userId         String?
  // References a Neon Auth (Better Auth) organization id. Nullable during the
  // single-user → org migration; legacy rows fall back to userId scoping.
  organizationId String?
  name           String
  mode           Mode
  description    String?
  specPath       String?
  planPath       String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  features       Feature[]
  repo           Repo?
  contextDocs    ProjectContextDoc[]

  @@index([userId])
  @@index([organizationId])
}

model Repo {
  id              String              @id @default(cuid())
  projectId       String              @unique
  project         Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner           String
  repo            String
  defaultBranch   String
  encryptedToken  String
  fileTree        Json?
  conventions     Json?
  lastIndexedAt   DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  embeddings      RepoFileEmbedding[]
}

model RepoFileEmbedding {
  id        String                       @id @default(cuid())
  repoId    String
  repo      Repo                         @relation(fields: [repoId], references: [id], onDelete: Cascade)
  path      String
  content   String
  embedding Unsupported("vector(1536)")
  updatedAt DateTime                     @default(now())

  @@unique([repoId, path])
  @@index([repoId])
}

model Feature {
  id                String        @id @default(cuid())
  projectId         String
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String
  idea              String
  status            FeatureStatus @default(DRAFT)
  questions         Json?
  answers           Json?
  spec              Json?
  plan              Json?
  approvedAt        DateTime?
  planStale         Boolean       @default(false)
  prUrl             String?
  prCreatedAt       DateTime?
  transcript        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  specVersions      SpecVersion[]
  decisions         Decision[]
}

model SpecVersion {
  id        String   @id @default(cuid())
  featureId String
  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  spec      Json
  note      String?
  createdAt DateTime @default(now())

  @@index([featureId, createdAt])
}

enum DecisionKind {
  DECISION
  CONSTRAINT
  OPEN_QUESTION
}

enum DecisionStatus {
  OPEN
  ACCEPTED
  SUPERSEDED
  REJECTED
}

enum DecisionSource {
  TRANSCRIPT
  CLARIFYING_ANSWER
  CONTEXT_DOC
  HUMAN_EDIT
  AI_PROPOSAL
}

// A single resolved choice with provenance — the spine node the spec
// materializes from. See docs/specs/decision-entity.md and
// docs/decisions/0001-decisions-not-tickets.md.
model Decision {
  id         String         @id @default(cuid())
  featureId  String
  feature    Feature        @relation(fields: [featureId], references: [id], onDelete: Cascade)
  kind       DecisionKind
  status     DecisionStatus
  statement  String
  rationale  String?
  // Provenance — same (sourceType, sourceId) shape retrieval already uses.
  // sourceId is interpreted per sourceType (e.g. the originating feature).
  sourceType DecisionSource
  sourceId   String?
  createdBy  String // user id, or "ai" for machine-distilled
  createdAt  DateTime       @default(now())
  decidedAt  DateTime?

  @@index([featureId])
  @@index([featureId, status])
}

model ProjectContextDoc {
  id         String                       @id @default(cuid())
  projectId  String
  project    Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  content    String
  mimeType   String
  byteLength Int
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
  embeddings ProjectContextDocEmbedding[]

  @@index([projectId])
}

model ProjectContextDocEmbedding {
  id        String                      @id @default(cuid())
  docId     String
  doc       ProjectContextDoc           @relation(fields: [docId], references: [id], onDelete: Cascade)
  chunkIx   Int
  content   String
  embedding Unsupported("vector(1536)")
  updatedAt DateTime                    @default(now())

  @@unique([docId, chunkIx])
  @@index([docId])
}
