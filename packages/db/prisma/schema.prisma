generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Mode {
  GREENFIELD
  EXISTING_SYSTEM
}

enum FeatureStatus {
  DRAFT
  QUESTIONS_GENERATED
  ANSWERED
  SPEC_DRAFTED
  SPEC_APPROVED
  PLAN_GENERATED
}

model Project {
  id          String    @id @default(cuid())
  name        String
  mode        Mode
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  features    Feature[]
}

model Feature {
  id         String        @id @default(cuid())
  projectId  String
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title      String
  idea       String
  status     FeatureStatus @default(DRAFT)
  questions  Json?
  answers    Json?
  spec       Json?
  plan       Json?
  approvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}
