# Marketing site env. These are read (via dotenv-cli) from the monorepo root
# .env at dev/build/start. All are optional — the site renders without them;
# the waitlist form only captures once RESEND_API_KEY (and an audience) is set.

# Resend API key — required for the "Request access" form to capture emails.
RESEND_API_KEY=

# Resend Audience to add waitlist sign-ups to. Create one in the Resend
# dashboard (Audiences) and paste its id here.
RESEND_AUDIENCE_ID=

# Optional: send an internal notification on each request. Both must be set,
# and the from-address must be on a Resend-verified domain.
RESEND_FROM_EMAIL=
ACCESS_REQUEST_NOTIFY_EMAIL=

# Public site URL — used for canonical/OG/sitemap. Set to the real domain in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3001
